# Copy this to .env and fill in your values

# PostgreSQL connection string (get from https://neon.tech for free)
DATABASE_URL="postgresql://user:password@host/civicpulse?sslmode=require"

# JWT Secret — change to a long random string in production
JWT_SECRET="civicpulse_super_secret_key_change_this_2026"

# Server port (local dev only)
PORT=5000
