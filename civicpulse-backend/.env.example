# CivicPulse Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (change this to a long random string in production)
JWT_SECRET=civicpulse_super_secret_key_change_in_production_2026

# Database
DB_PATH=./civicpulse.db

# File Upload
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads

# Admin credentials (for seeding)
ADMIN_EMAIL=admin@civicpulse.in
ADMIN_PASSWORD=Admin@123

# CORS Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
